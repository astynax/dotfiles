# -*- mode:shell-script -*-

local FD=(fd -t directory --exact-depth 1 '.*')

local Q=()
if [ -n "$1" ]; then
    Q=(--query "$1")
fi

local TARGET=$(
    cat <($FD -C "$HOME" Projects) \
        <($FD -C "$HOME" IdeaProjects) \
        | sort | fzf $Q)

if [ -n "$TARGET" ]; then
    pushd "$HOME/$TARGET"
fi
